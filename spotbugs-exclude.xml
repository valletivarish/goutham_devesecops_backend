<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude mutable object exposure warnings from Spring constructor injection -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!-- Exclude CT_CONSTRUCTOR_THROW for Spring-managed beans -->
    <Match>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>

    <!-- Exclude dead local store in Spring service methods -->
    <Match>
        <Bug pattern="DLS_DEAD_LOCAL_STORE"/>
    </Match>
</FindBugsFilter>
